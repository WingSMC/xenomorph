{
    "name": "xenomorph",
    "displayName": "Xenomorph",
    "description": "Xenomorph language support",
    "version": "0.1.0",
    "engines": {
        "vscode": "^1.54.0"
    },
    "author": {
        "name": "WingSMC",
        "url": "https://github.com/WingSMC"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/WingSMC/xenomorph.git",
        "directory": "extensions/vscode"
    },
    "categories": [
        "Debuggers",
        "Formatters",
        "Linters",
        "Programming Languages",
        "Snippets",
        "Testing"
    ],
    "scripts": {
        "build": "cd client && tsc && cd .. && nr setup:lsp",
        "setup:lsp": "cd ../../ && ((cp ./target/release/xenomorph_lsp{,.exe} ./extensions/vscode/server/ || true) 2>/dev/null) && cd ./extensions/vscode",
        "package": "vsce package"
    },
    "main": "./client/out/extension",
    "activationEvents": [
        "onLanguage:xenomorph",
        "onLanguage:xenomorph-toml"
    ],
    "contributes": {
        "languages": [
            {
                "id": "xenomorph",
                "aliases": [
                    "xeno"
                ],
                "extensions": [
                    ".xen"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./icons/logo-black.png",
                    "dark": "./icons/logo-white.png"
                }
            },
            {
                "id": "xenomorph-toml",
                "aliases": [
                    "TOML"
                ],
                "filenames": [
                    ".xenomorphrc"
                ],
                "icon": {
                    "light": "./icons/logo.png",
                    "dark": "./icons/logo.png"
                }
            }
        ],
        "grammars": [
            {
                "language": "xenomorph",
                "scopeName": "source.xenomorph",
                "path": "./syntaxes/xenomorph.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "xenomorph",
                "path": "./snippets/snippets.json"
            }
        ]
    }
}
