{
    "name": "xenomorph",
    "displayName": "Xenomorph",
    "description": "Xenomorph language support",
    "version": "0.1.1",
    "publisher": "WingSMC",
    "engines": {
        "vscode": "^1.75.0"
    },
    "author": {
        "name": "WingSMC",
        "url": "https://github.com/WingSMC"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/WingSMC/xenomorph.git",
        "directory": "extensions/vscode"
    },
    "categories": [
        "Debuggers",
        "Formatters",
        "Linters",
        "Programming Languages",
        "Snippets",
        "Testing"
    ],
    "scripts": {
        "all": "nr build && nr package",
        "build": "cd client && nr build && cd .. && nr setup:lsp",
        "setup:lsp": "node ./scripts/copy-lsp.mjs",
        "package": "node ./scripts/package.mjs",
        "publish": "node ./scripts/package.mjs --publish"
    },
    "main": "./client/out/extension",
    "icon": "./icons/logo-white.png",
    "extensionDependencies": [
        "tamasfe.even-better-toml"
    ],
    "contributes": {
        "languages": [
            {
                "id": "xenomorph",
                "aliases": [
                    "xenomorph"
                ],
                "extensions": [
                    ".xen"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./icons/logo-black.png",
                    "dark": "./icons/logo-white.png"
                }
            }
        ],
        "grammars": [
            {
                "language": "xenomorph",
                "scopeName": "source.xenomorph",
                "path": "./syntaxes/xenomorph.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "xenomorph",
                "path": "./snippets/snippets.json"
            }
        ],
        "configurationDefaults": {
            "evenBetterToml.schema.associations": {
                ".*xenomorph\\.toml$": "./.xenomorph/xenomorph.schema.json"
            }
        }
    }
}
